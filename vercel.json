{
  "version": 2,
  "buildCommand": "npm run build && npx esbuild src/api-router.ts --bundle --outfile=api/router.js --platform=node --format=esm --packages=external --log-level=info",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/router.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/master/reset-balance",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/router" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization" }
      ]
    }
  ]
}
